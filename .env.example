# ─────────────────────────────────────────────
#  Job Scraper 설정 파일
#  이 파일을 복사해서 .env 로 저장 후 값을 채워주세요
#  cp .env.example .env
# ─────────────────────────────────────────────

# ── 검색 키워드 (콤마로 구분, 하나라도 포함된 공고 수집) ──────
# 예시 1 (개발자):   KEYWORDS=Python,백엔드,Django,FastAPI,AWS
# 예시 2 (로봇):     KEYWORDS=ROS,자율주행,OpenCV,임베디드,SLAM
# 예시 3 (디자이너): KEYWORDS=UX,UI디자인,Figma,제품디자인
KEYWORDS=Python,백엔드,개발자

# ── 제외 키워드 (포함된 공고 제외) ────────────────────────────
EXCLUDE_KEYWORDS=경력 10년,수석,팀장,시니어

# ── 지역 설정 ──────────────────────────────────────────────────
# 이메일에 표시될 지역 이름
LOCATION_LABEL=수도권

# 사람인 지역 코드 (비우면 전국)
# R1=서울 / R2=경기 / R6=인천 / R13=경기남부
SARAMIN_LOC_CD=R1,R2,R6

# ── 사람인 API 키 (https://oapi.saramin.co.kr 에서 무료 발급) ─
SARAMIN_API_KEY=

# ── Gmail 설정 ─────────────────────────────────────────────────
# 발신 Gmail 주소
GMAIL_USER=your_email@gmail.com

# Gmail 앱 비밀번호 (Google 계정 → 보안 → 앱 비밀번호)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# 수신 이메일 (본인 Gmail 또는 다른 주소)
RECIPIENT_EMAIL=your_email@gmail.com
